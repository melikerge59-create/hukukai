{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/chat.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/payment.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/payment-callback.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
