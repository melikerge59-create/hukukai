# HukukAI — Required Environment Variables
# Copy this file to .env.local for local development.
# Set these in Vercel project settings for production.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Server-side only — bypasses RLS

# OpenAI
OPENAI_API_KEY=sk-...

# Iyzipay (Turkish payment gateway)
IYZICO_API_KEY=your-iyzipay-api-key
IYZICO_SECRET_KEY=your-iyzipay-secret-key

# Iyzipay base URL
# Sandbox (default): https://sandbox-api.iyzipay.com
# Production:        https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
