# Frontend Environment Variables (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend Environment Variables (Vercel Only)
# These should be set in Vercel Dashboard → Settings → Environment Variables

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Iyzipay (Turkish Payment Gateway)
IYZICO_API_KEY=your-iyzipay-api-key
IYZICO_SECRET_KEY=your-iyzipay-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Site URL
SITE_URL=https://your-app.vercel.app
